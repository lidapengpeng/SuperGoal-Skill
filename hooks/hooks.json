{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_audit.py\"",
            "timeout": 15,
            "statusMessage": "SuperGoal completion audit"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "^(supergoal_luna_executor|supergoal_researcher|supergoal_reviewer)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/subagent_audit.py\" --hook-start",
            "timeout": 15,
            "statusMessage": "SuperGoal state-scope baseline"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^(supergoal_luna_executor|supergoal_researcher|supergoal_reviewer)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/subagent_audit.py\" --hook-stop",
            "timeout": 15,
            "statusMessage": "SuperGoal state-scope advisory"
          }
        ]
      }
    ]
  }
}
