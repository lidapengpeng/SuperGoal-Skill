# SuperGoal default profile: merge this adaptive profile into
# ~/.codex/config.toml or <repo>/.codex/config.toml.
#
# It caps the current Codex 0.144 runtime at ten spawned agent threads.
# The manifest separately caps all direct task records at ten; the controller
# chooses the actual fan-out from its validated dependency DAG.
model = "gpt-5.6-sol"
model_reasoning_effort = "ultra"

[features]
goals = true

[agents]
max_threads = 10
max_depth = 1

# The optional version-pinned v2 profile is a separate, mutually exclusive
# sample: config/config.v2-strict.toml.snippet. Do not merge its contents with
# this adaptive [agents] profile.
